# Git configuration
[user]
name  = Kartik Shenoy
email = theresmorethanoneway@gmail.com

[core]
editor = nvim -u ~/.config/nvim/init-min.lua

[init]
defaultBranch = main

[color "branch"]
current = green

[color "diff"]
meta = yellow
frag = magenta
old = red bold
plain = white

[color "status"]
added = yellow
untracked = cyan

[diff]
tool = nvim
# Better handling of code moves than the default Myers algorithm
algorithm = histogram
# Highlight moved lines in a distinct color instead of showing them as add+delete
colorMoved = default
# Detect both renames and copies (default only detects renames)
renames = copies

[difftool]
prompt = false

[difftool "nvim"]
cmd = nvim -u ~/.config/nvim/init-min.lua -d $LOCAL $REMOTE

[difftool "nvim-LazyVim"]
cmd = NVIM_APPNAME=nvim-LazyVim nvim -d $LOCAL $REMOTE

[difftool "gvim"]
cmd = gvim -f -d $LOCAL $REMOTE

[fetch]
# Remove stale remote-tracking branches when the remote branch is deleted
prune = true

[merge]
tool = nvim
# Show the common ancestor in conflict markers (base|ours vs theirs) for more context
conflictstyle = zdiff3

[mergetool]
prompt = false

[mergetool "nvim"]
cmd = nvim -u ~/.config/nvim/init-min.lua -c MergeInit "$BASE" "$REMOTE" "$LOCAL" "$MERGED"

[mergetool "nvim-LazyVim"]
cmd = NVIM_APPNAME=nvim-LazyVim nvim -c MergeInit "$BASE" "$REMOTE" "$LOCAL" "$MERGED"

[mergetool "gvim"]
cmd = gvim -f "$BASE" "$REMOTE" "$LOCAL" "$MERGED" -c MergeInit

[mergetool "meld"]
cmd = meld $LOCAL $MERGED $REMOTE --output $MERGED --diff $LOCAL $MERGED --diff $REMOTE $MERGED --diff $BASE $REMOTE --diff $BASE $LOCAL --diff $REMOTE $LOCAL

[pull]
rebase = true

[rerere]
# Record conflict resolutions and replay them automatically if the same conflict recurs
enabled = true

[alias]
# https://haacked.com/archive/2014/07/28/github-flow-aliases/
# Using '!' as prefix allows running any command in the shell and it doesn't have to be a git command.
# Thus, if we want to create an alias to run multiple commands by chaining them together, we have to use '!'
# List all aliases
alias = !git config -l | grep alias | cut -c 7-

# Shorthands
st = status
dn = diff --name-only
dt = difftool
dw = diff --word-diff
mt = mergetool
br = branch
re = restore
sw = switch
ci = commit

# Colorized graph log of all branches with author and relative date
pplog = log --color --pretty=format:' %C(yellow)%h%C(reset) %s %C(green)(%cr) %C(bold blue)<%an>%C(auto)%d'
lg = "!f() { git pplog --abbrev-commit --graph HEAD \"${@}\"; }; f"
lga = !git pplog --abbrev-commit --graph --all
# Same as above but for a single file
flog = !git pplog --abbrev-commit --all --follow

# Show the most recent commit
last = log -1 HEAD

# Print the repo root path
root = rev-parse --show-toplevel

# Unstage files without discarding changes
unstage = restore --staged

# Amend the last commit without changing its message
recommit = commit --amend --no-edit

# Stash everything including untracked files (default stash skips them)
stsh = stash --include-untracked

# Show commits on the remote not yet pulled / commits not yet pushed
incoming = log HEAD..@{upstream}
outgoing = log @{upstream}..HEAD

# Run difftool/mergetool with gvim or other nvim distros instead of the default tool
dtg = difftool --tool=gvim
mtg = mergetool --tool=gvim
dtl = difftool --tool=nvim-LazyVim
mtl = mergetool --tool=nvim-LazyVim

# Diff against upstream if set, else origin/<current branch> (no fetch). eg.
# - git CMD REF  →  Run CMD against REF
# - git CMD      →  Run CMD against upstream if set, else origin/<current branch>
du-impl = "!f() {\
  cmd=\"$1\"; ref=\"$2\";\
  if [ -n \"$ref\" ]; then\
    git \"$cmd\" \"$ref\";\
  else\
    upstream=$(git rev-parse --abbrev-ref @{upstream} 2>/dev/null);\
    if [ -n \"$upstream\" ]; then\
      git \"$cmd\" \"$upstream\";\
    else\
      git \"$cmd\" \"origin/$(git rev-parse --abbrev-ref HEAD)\";\
    fi;\
  fi;\
}; f"
dtu = "!git du-impl dt"
dnu = "!git du-impl dn"

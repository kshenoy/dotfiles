# Git configuration
[user]
name  = Kartik Shenoy
email = theresmorethanoneway@gmail.com

[core]
editor = nvim -u ~/.config/nvim/init-min.lua

[init]
defaultBranch = main

[color "branch"]
current = green

[color "diff"]
meta = yellow
frag = magenta
old = red bold
plain = white

[color "status"]
added = yellow
untracked = cyan

[diff]
tool = nvim
# Better handling of code moves than the default Myers algorithm
algorithm = histogram
# Highlight moved lines in a distinct color instead of showing them as add+delete
colorMoved = default
# Detect both renames and copies (default only detects renames)
renames = copies

[difftool]
prompt = false

[difftool "nvim"]
cmd = nvim -u ~/.config/nvim/init-min.lua -d $LOCAL $REMOTE

[difftool "nvim-LazyVim"]
cmd = NVIM_APPNAME=nvim-LazyVim nvim -d $LOCAL $REMOTE

[difftool "gvim"]
cmd = gvim -f -d $LOCAL $REMOTE

[fetch]
# Remove stale remote-tracking branches when the remote branch is deleted
prune = true

[merge]
tool = nvim
# Show the common ancestor in conflict markers (base|ours vs theirs) for more context
conflictstyle = zdiff3

[mergetool]
prompt = false

[mergetool "nvim"]
cmd = nvim -u ~/.config/nvim/init-min.lua -c MergeInit "$BASE" "$REMOTE" "$LOCAL" "$MERGED"

[mergetool "nvim-LazyVim"]
cmd = NVIM_APPNAME=nvim-LazyVim nvim -c MergeInit "$BASE" "$REMOTE" "$LOCAL" "$MERGED"

[mergetool "gvim"]
cmd = gvim -f "$BASE" "$REMOTE" "$LOCAL" "$MERGED" -c MergeInit

[mergetool "meld"]
cmd = meld $LOCAL $MERGED $REMOTE --output $MERGED --diff $LOCAL $MERGED --diff $REMOTE $MERGED --diff $BASE $REMOTE --diff $BASE $LOCAL --diff $REMOTE $LOCAL

[pull]
rebase = true

[push]
autoSetupRemote = true

[rerere]
# Record conflict resolutions and replay them automatically if the same conflict recurs
enabled = true

[alias]
# https://haacked.com/archive/2014/07/28/github-flow-aliases/
# Using '!' as prefix allows running any command in the shell and it doesn't have to be a git command.
# Thus, if we want to create an alias to run multiple commands by chaining them together, we have to use '!'
# List all aliases
alias = !git config --list | grep alias | cut -c 7-

# Shorthands
st = status
dn = diff --name-only
dt = difftool
dw = diff --word-diff
mt = mergetool
br = branch
re = restore
sw = switch
ci = commit

# Colorized graph log of all branches with author and relative date
pplog = log --color --date=short --pretty=format:' %C(yellow)%h%C(reset) %s %C(green)(%ad) %C(bold blue)<%an>%C(auto)%d'

# Pretty graph log. Shows HEAD; origin/main; and upstream if set, else origin/<branch> if that remote ref exists eg.
# if current branch is:
# * main - shows HEAD, origin/main
# * 'foo' branch - shows HEAD, origin/main, and UPSTREAM or origin/foo
lg = "!f() {\
  default=$(git rev-parse --abbrev-ref origin/HEAD 2>/dev/null);\
  git rev-parse --verify \"$default\" >/dev/null 2>&1 || default=origin/main;\
  git rev-parse --verify \"$default\" >/dev/null 2>&1 || default="";\
  extra=$(git resolve-upstream);\
  git rev-parse --verify \"$extra\" >/dev/null 2>&1 || extra=\"\";\
  git pplog --abbrev-commit --graph HEAD $default $extra \"${@}\";\
}; f"

# Same as above but for a single file
flog = !git pplog --abbrev-commit --all --follow

# Show the most recent commit
last = log -1 HEAD

# Print the repo root path
root = rev-parse --show-toplevel

# Unstage files without discarding changes
unstage = restore --staged

# Amend the last commit without changing its message
recommit = commit --amend --no-edit

# Stash everything including untracked files (default stash skips them)
stsh = stash --include-untracked

# Show commits on the remote not yet pulled / commits not yet pushed
incoming = log HEAD..@{upstream}
outgoing = log @{upstream}..HEAD

# Run difftool/mergetool with gvim or other nvim distros instead of the default tool
dtg = difftool --tool=gvim
mtg = mergetool --tool=gvim
dtl = difftool --tool=nvim-LazyVim
mtl = mergetool --tool=nvim-LazyVim

# Returns upstream if set, else origin/<current branch>
resolve-upstream = "!f() {\
  branch=$(git rev-parse --abbrev-ref '@{upstream}' 2>/dev/null);\
  if [ -z \"$branch\" ]; then\
    branch=\"origin/$(git rev-parse --abbrev-ref HEAD)\";\
  fi;\
  echo \"$branch\";\
}; f"

# Resolve upstream and run specified diff command
# git CMD  →  Run CMD against upstream if set, else origin/<current branch>
diff-upstream-impl = "!f() {\
  cmd=\"$1\"; shift;\
  branch=\"$(git resolve-upstream)\";\
  git \"$cmd\" \"$branch\" \"$@\";\
}; f"
dnu = "!git diff-upstream-impl dn"
dtu = "!git diff-upstream-impl dt"

# Fetch origin/BRANCH. eg.
# - git fob BRANCH  → fetch origin/BRANCH
# - git fob         → fetch tracking upstream (falls back to current branch name if no upstream set)
fob = "!f() {\
  branch=\"${1:-$(git resolve-upstream)}\";\
  branch=\"${branch#origin/}\";\
  git fetch origin \"$branch\";\
}; f"
fom = !git fob main

# Fetch and switch to remote branch, creating it locally if needed, and set upstream to origin/<BRANCH>
cob = "!f() {\
  branch=\"${1#origin/}\";\
  git fetch origin \"$branch\" && git switch \"$branch\" && git branch --set-upstream-to=\"origin/$branch\";\
}; f"

# Delete remote-tracking refs not tracked by any local branch
# (needs bash -c explicitly since process substitution <(...) is not POSIX sh)
remote-prune = "!bash -c 'f() { \
  comm -23 \
    <(git branch --remotes | grep -v HEAD | sed \"s/^ *//\" | sort) \
    <(git branch --format=\"%(upstream:short)\" | grep -v \"^$\" | sort) | \
  xargs git branch -dr; \
}; f'"
